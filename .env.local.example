# Copy this file to ".env.local" and fill in real values.
# .env.local is git-ignored and never committed.

# --- Supabase (Project Settings -> API) -----------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (chatbot / RAG, https://platform.openai.com/api-keys) -----------
OPENAI_API_KEY=sk-...
# Model for chat responses (default: gpt-4o)
OPENAI_MODEL=gpt-4o
# Model for embeddings (default: text-embedding-3-small, 1536 dims)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Admin dashboard (protect /admin and document upload) -------------------
# Set any strong password; leave empty to disable auth (dev only)
ADMIN_SECRET=your-strong-admin-password

# --- Resend (contact form emails, https://resend.com) ----------------------
RESEND_API_KEY=your-resend-api-key
# Inbox that receives contact-form submissions:
CONTACT_NOTIFICATION_EMAIL=elahimahdi72@gmail.com
# Optional verified sender. Defaults to Resend's shared testing sender, which
# can only deliver to your own account email until you verify a domain.
CONTACT_FROM_EMAIL="Mehdi Elahi Website <onboarding@resend.dev>"
